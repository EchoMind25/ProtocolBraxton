# ═══════════════════════════════════════════════════════
# PROTOCOL BRAXTON — Environment Configuration
# ═══════════════════════════════════════════════════════

# Supabase — Get these from your Supabase project dashboard
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Claude API — Get from console.anthropic.com
# Used for the in-app chat assistant
ANTHROPIC_API_KEY=sk-ant-your-key-here

# App URL — Used for auth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000
